{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "coc serve (internal)",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "coc", "serve", "--mode", "internal", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "coc serve (public)",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "coc", "serve", "--mode", "public", "--host", "127.0.0.1", "--port", "8001"],
      "port": 8001
    },
    {
      "name": "coc serve (internal, reload)",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "coc", "serve", "--mode", "internal", "--host", "127.0.0.1", "--port", "8000", "--reload"],
      "port": 8000
    }
  ]
}
