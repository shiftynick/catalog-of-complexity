{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog-of-complexity.org/schemas/metric.schema.json",
  "title": "Metric",
  "description": "Definition of a measure applied to systems, including when and how.",
  "type": "object",
  "required": [
    "id",
    "slug",
    "name",
    "family",
    "status",
    "value_type",
    "description",
    "applicability",
    "estimation_methods",
    "evidence_requirements"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^mtr-[0-9]{6}--[a-z0-9-]+$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": { "type": "string", "minLength": 1 },
    "family": {
      "type": "string",
      "description": "Slug referencing taxonomy/source/metric-families.yaml."
    },
    "status": {
      "type": "string",
      "enum": ["proposed", "canonical", "deprecated"]
    },
    "value_type": {
      "type": "string",
      "enum": ["continuous", "discrete", "categorical", "ordinal", "boolean"]
    },
    "unit": { "type": ["string", "null"] },
    "directionality": {
      "type": "string",
      "enum": ["more-is-better", "less-is-better", "context-dependent", "neither"]
    },
    "description": { "type": "string", "minLength": 1 },
    "applicability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requires": { "type": "array", "items": { "type": "string" } },
        "excludes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "estimation_methods": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "normalization": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy": { "type": "string" }
      }
    },
    "evidence_requirements": {
      "type": "object",
      "required": ["minimum_source_count", "review_required"],
      "additionalProperties": false,
      "properties": {
        "minimum_source_count": { "type": "integer", "minimum": 1 },
        "review_required": { "type": "boolean" }
      }
    }
  }
}
