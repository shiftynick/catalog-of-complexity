{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog-of-complexity.org/schemas/task.schema.json",
  "title": "Task",
  "description": "A unit of work routed through the directory-based queue under ops/tasks/.",
  "type": "object",
  "required": [
    "id",
    "type",
    "skill",
    "state",
    "output_targets",
    "acceptance_tests",
    "lease",
    "created_at"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^tsk-[0-9]{8}-[0-9]{6}$"
    },
    "type": {
      "type": "string",
      "enum": [
        "bootstrap",
        "scout-systems",
        "define-metrics",
        "profile-system",
        "extract-observations",
        "review-records",
        "materialize-warehouse",
        "build-release",
        "analyze-archetypes"
      ]
    },
    "skill": { "type": "string" },
    "state": {
      "type": "string",
      "enum": [
        "inbox",
        "ready",
        "leased",
        "running",
        "blocked",
        "review",
        "done",
        "failed",
        "archive"
      ]
    },
    "priority": {
      "type": "string",
      "enum": ["low", "normal", "high", "urgent"],
      "default": "normal"
    },
    "system_id": { "type": ["string", "null"] },
    "metric_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "source_refs": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "output_targets": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "acceptance_tests": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "reviewer_skill": { "type": "string" }
      }
    },
    "lease": {
      "type": "object",
      "required": ["ttl_minutes", "max_attempts"],
      "additionalProperties": false,
      "properties": {
        "ttl_minutes": { "type": "integer", "minimum": 1 },
        "max_attempts": { "type": "integer", "minimum": 1 },
        "attempts": { "type": "integer", "minimum": 0, "default": 0 },
        "leased_by": { "type": ["string", "null"] },
        "leased_at": { "type": ["string", "null"] },
        "last_heartbeat": { "type": ["string", "null"] }
      }
    },
    "notes": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
