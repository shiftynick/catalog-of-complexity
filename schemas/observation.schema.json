{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog-of-complexity.org/schemas/observation.schema.json",
  "title": "Observation",
  "description": "A system-metric assertion with evidence. One per line in JSONL files.",
  "type": "object",
  "required": [
    "observation_id",
    "system_id",
    "metric_id",
    "value_kind",
    "confidence",
    "source_refs",
    "evidence_refs",
    "review_state"
  ],
  "additionalProperties": false,
  "properties": {
    "observation_id": {
      "type": "string",
      "pattern": "^obs-[0-9a-f]{8}$"
    },
    "system_id": {
      "type": "string",
      "pattern": "^sys-[0-9]{6}--[a-z0-9-]+$"
    },
    "metric_id": {
      "type": "string",
      "pattern": "^mtr-[0-9]{6}--[a-z0-9-]+$"
    },
    "value": {
      "type": ["number", "string", "boolean", "null"]
    },
    "unit": { "type": ["string", "null"] },
    "value_kind": {
      "type": "string",
      "enum": [
        "direct",
        "derived",
        "proxy",
        "simulation",
        "expert_estimate",
        "unknown"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "method": { "type": ["string", "null"] },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^src-[0-9]{6}--[a-z0-9-]+$"
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^evi-[0-9a-f]{8}$"
      }
    },
    "temporal_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string" },
        "start": { "type": "string" },
        "end": { "type": "string" }
      }
    },
    "spatial_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string" }
      }
    },
    "review_state": {
      "type": "string",
      "enum": ["proposed", "validated", "superseded", "rejected"]
    },
    "observed_at": { "type": "string", "format": "date-time" }
  }
}
