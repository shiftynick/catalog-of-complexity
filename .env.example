# Copy to .env (git-ignored) and fill in for local agent runs.

# Provider API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: Firecrawl or other scraping providers (deferred)
# FIRECRAWL_API_KEY=

# Optional: logging / observability (deferred)
# OTEL_EXPORTER_OTLP_ENDPOINT=

# Default lease TTL for task queue, in minutes
COC_LEASE_TTL_MIN=90
