# Catalog-of-Complexity specific
# Warehouse is fully regenerable from registry — do not commit.
warehouse/parquet/*.parquet
warehouse/duckdb/*.duckdb
warehouse/duckdb/*.wal

# Agent scratchpad — ephemeral.
workspace/

# Run reports and ephemeral ops state.
ops/runs/

# Release artifacts — regenerable, sometimes published out-of-band.
releases/*/data/

# Local agent caches
.claude/cache/
.codex/cache/
